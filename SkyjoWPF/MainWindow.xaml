<Window x:Class="SkyjoWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Skyjo PC - Édition Réseau" Height="750" Width="800" Background="#1e272e">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtNomAdversaire" Text="ADVERSAIRE" Foreground="#e74c3c" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
        <ItemsControl x:Name="ItemsGrilleIA" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" Rows="3" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Affichage}" Width="60" Height="90" Margin="5" FontSize="20" FontWeight="Bold" IsHitTestVisible="False"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <StackPanel Margin="0,0,20,0">
                <TextBlock Text="Pioche" Foreground="White" HorizontalAlignment="Center"/>
                <Button x:Name="BtnPioche" Content="Dos" Width="80" Height="120" FontSize="20" Background="#34495e" Foreground="White" Click="BtnPioche_Click"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Défausse" Foreground="White" HorizontalAlignment="Center"/>
                <Button x:Name="BtnDefausse" Width="80" Height="120" FontSize="24" FontWeight="Bold" Click="BtnDefausse_Click"/>
            </StackPanel>
        </StackPanel>

        <ItemsControl x:Name="ItemsGrille" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" Rows="3" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Affichage}" Width="60" Height="90" Margin="5" FontSize="20" FontWeight="Bold" Click="Carte_Click"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock x:Name="TxtNomJoueur" Grid.Row="4" Text="VOUS (P1)" Foreground="#2ecc71" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>

        <Canvas x:Name="OverlayCanvas" Grid.RowSpan="5" IsHitTestVisible="False" Panel.ZIndex="100">
            <TextBlock x:Name="CurseurIA" Text="🖐️" FontSize="40" Visibility="Hidden" Canvas.Left="-50" Canvas.Top="-50">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="CurseurTransform" X="0" Y="0"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Canvas>

        <Border x:Name="MenuPanel" Grid.RowSpan="5" Background="#2c3e50" Panel.ZIndex="200">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="SKYJO LAN EDITION" FontSize="36" FontWeight="Bold" Foreground="White" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                <Button Content="Jouer en Solo (contre IA)" Width="280" Height="50" Margin="10" FontSize="18" Click="BtnSolo_Click"/>

                <TextBlock Text="Réseau Local (LAN)" Foreground="#e67e22" FontSize="20" FontWeight="Bold" Margin="0,20,0,10" HorizontalAlignment="Center"/>

                <Button Content="Héberger une partie" Width="280" Height="40" Margin="5" FontSize="16" Click="BtnHeberger_Click" Background="#27ae60" Foreground="White"/>

                <Button Content="Scanner le réseau" Width="280" Height="40" Margin="5,15,5,5" FontSize="16" Click="BtnScanner_Click" Background="#2980b9" Foreground="White"/>

                <ListBox x:Name="ListServeurs" Width="280" Height="100" Margin="5" Background="#ecf0f1" FontSize="14" DisplayMemberPath="NomAffichage"/>

                <Button Content="Rejoindre la partie sélectionnée" Width="280" Height="40" Margin="5" FontSize="16" Click="BtnRejoindre_Click"/>

                <TextBlock x:Name="TxtStatutMenu" Foreground="Yellow" FontSize="14" Margin="0,10,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>